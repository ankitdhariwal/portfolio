# ── Dependencies ────────────────────────────────────────────
node_modules/
package-lock.json
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ─────────────────────────────────────
/.next/
/out/
/build/

# ── Environment variables (never commit secrets) ─────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Vercel ───────────────────────────────────────────────────
.vercel

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing / Coverage ───────────────────────────────────────
/coverage
/.nyc_output

# ── Debug logs ───────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── Editor / IDE ─────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Certificates / Keys ──────────────────────────────────────
*.pem
*.key
*.p12
*.cert

# ── Misc ─────────────────────────────────────────────────────
.cache/
*.log
